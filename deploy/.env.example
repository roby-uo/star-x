# star-X public Docker deployment
# Copy this file to .env and replace every CHANGE_ME value before first start.

STAR_X_IMAGE=ghcr.io/roby-uo/star-x:latest
BIND_HOST=0.0.0.0
SERVER_PORT=8080
TZ=Asia/Shanghai

POSTGRES_USER=starx
POSTGRES_DB=starx
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD

ADMIN_EMAIL=admin@star-x.local
ADMIN_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD

# Generate distinct values, e.g. openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_A_64_CHARACTER_HEX_SECRET
TOTP_ENCRYPTION_KEY=CHANGE_ME_USE_A_DIFFERENT_64_CHARACTER_HEX_SECRET

# Optional. Leave empty to use Redis's default ACL user.
REDIS_USERNAME=
# Optional. Leave empty unless Redis authentication is required.
REDIS_PASSWORD=
